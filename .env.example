# OpenAI API key for AI tag suggestions (optional — app works without it)
OPENAI_API_KEY=your-openai-api-key-here

# Notion integration token (optional — app works without it)
# Create an internal integration at https://www.notion.so/my-integrations
NOTION_API_KEY=your-notion-api-key-here

# Notion database ID (auto-created on first promote if not set)
NOTION_DATABASE_ID=
